{
    "manifest_version": 3,
    "name": "History Exporter",
    "version": "1.0",
    "description": "Exports browsing history to a backend API",
    "permissions": ["history", "activeTab"],
    "icons": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
      }
    },
    "background": {
      "service_worker": "background.js",
      "type": "module"
    },
    "host_permissions": ["http://localhost:8090/*", "http://localhost:3030/*"]
  }